{
  "manifest_version": 3,
  "name": "Amazon Order Exporter",
  "version": "1.1.18",
  "description": "Export your Amazon order history as CSV for budgeting",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.ca/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.ca/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
